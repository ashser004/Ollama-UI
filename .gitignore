AIUI/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# --- OS files ---
Thumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# --- Logs / temp ---
*.log
*.tmp
*.bak
*.partial

# --- Distribution / packaging ---
*.spec
*.manifest

# --- Gemini agent data ---
.gemini/
